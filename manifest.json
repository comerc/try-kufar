{
  "manifest_version": 3,
  "name": "Kufar USD Prices",
  "description": "Shows USD equivalents next to BYN prices on Kufar pages.",
  "version": "0.1.1",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.nbrb.by/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://auto.kufar.by/*",
        "https://re.kufar.by/*"
      ],
      "js": [
        "src/content.js"
      ],
      "css": [
        "src/content.css"
      ],
      "run_at": "document_idle"
    }
  ]
}
